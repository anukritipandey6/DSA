/* Problem: Given weighted graph with non-negative edges, compute shortest path from source using priority queue. */
#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

#define MAX 100

// Structure for adjacency list node
typedef struct Node {
    int vertex;
    int weight;
    struct Node* next;
} Node;

// Structure for graph
typedef struct {
    Node* head[MAX];
} Graph;

// Min Heap structure
typedef struct {
    int vertex;
    int dist;
} HeapNode;

typedef struct {
    int size;
    HeapNode heap[MAX];
} MinHeap;

// Function to create graph
void initGraph(Graph* g, int V) {
    for (int i = 0; i < V; i++)
        g->head[i] = NULL;
}

// Add edge
void addEdge(Graph* g, int u, int v, int w) {
    Node* newNode = (Node*)malloc(sizeof(Node));
    newNode->vertex = v;
    newNode->weight = w;
    newNode->next = g->head[u];
    g->head[u] = newNode;
}

// Swap heap nodes
void swap(HeapNode* a, HeapNode* b) {
    HeapNode temp = *a;
    *a = *b;
    *b = temp;
}

// Heapify up
void heapifyUp(MinHeap* pq, int idx) {
    while (idx && pq->heap[(idx - 1) / 2].dist > pq->heap[idx].dist) {
        swap(&pq->heap[idx], &pq->heap[(idx - 1) / 2]);
        idx = (idx - 1) / 2;
    }
}

// Heapify down
void heapifyDown(MinHeap* pq, int idx) {
    int smallest = idx;
    int left = 2 * idx + 1;
    int right = 2 * idx + 2;

    if (left < pq->size && pq->heap[left].dist < pq->heap[smallest].dist)
        smallest = left;

    if (right < pq->size && pq->heap[right].dist < pq->heap[smallest].dist)
        smallest = right;

    if (smallest != idx) {
        swap(&pq->heap[idx], &pq->heap[smallest]);
        heapifyDown(pq, smallest);
    }
}

// Insert into heap
void push(MinHeap* pq, int vertex, int dist) {
    pq->heap[pq->size].vertex = vertex;
    pq->heap[pq->size].dist = dist;
    heapifyUp(pq, pq->size);
    pq->size++;
}

// Extract min
HeapNode pop(MinHeap* pq) {
    HeapNode root = pq->heap[0];
    pq->heap[0] = pq->heap[pq->size - 1];
    pq->size--;
    heapifyDown(pq, 0);
    return root;
}

// Dijkstra function
void dijkstra(Graph* g, int V, int src) {
    int dist[MAX];
    
    for (int i = 0; i < V; i++)
        dist[i] = INT_MAX;

    MinHeap pq;
    pq.size = 0;

    dist[src] = 0;
    push(&pq, src, 0);

    while (pq.size > 0) {
        HeapNode node = pop(&pq);
        int u = node.vertex;

        for (Node* temp = g->head[u]; temp != NULL; temp = temp->next) {
            int v = temp->vertex;
            int weight = temp->weight;

            if (dist[u] + weight < dist[v]) {
                dist[v] = dist[u] + weight;
                push(&pq, v, dist[v]);
            }
        }
    }

    // Print result
    printf("Vertex \t Distance from Source\n");
    for (int i = 0; i < V; i++)
        printf("%d \t %d\n", i, dist[i]);
}

// Driver code
int main() {
    Graph g;
    int V = 5;

    initGraph(&g, V);

    addEdge(&g, 0, 1, 10);
    addEdge(&g, 0, 4, 5);
    addEdge(&g, 1, 2, 1);
    addEdge(&g, 1, 4, 2);
    addEdge(&g, 2, 3, 4);
    addEdge(&g, 3, 0, 7);
    addEdge(&g, 3, 2, 6);
    addEdge(&g, 4, 1, 3);
    addEdge(&g, 4, 2, 9);
    addEdge(&g, 4, 3, 2);

    int source = 0;
    dijkstra(&g, V, source);

    return 0;
}
