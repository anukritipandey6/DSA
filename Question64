/*Problem: Perform BFS from a given source using queue.
Input:
- n
- adjacency list
- source s
Output:
- BFS traversal order
*/
#include <stdio.h>
#include <stdlib.h>

#define MAX 100

// Queue structure
int queue[MAX], front = -1, rear = -1;

void enqueue(int x) {
    if (rear == MAX - 1) return;
    if (front == -1) front = 0;
    queue[++rear] = x;
}

int dequeue() {
    if (front == -1 || front > rear) return -1;
    return queue[front++];
}

int isEmpty() {
    return front == -1 || front > rear;
}

// BFS function
void BFS(int n, int adj[MAX][MAX], int s) {
    int visited[MAX] = {0};

    enqueue(s);
    visited[s] = 1;

    while (!isEmpty()) {
        int node = dequeue();
        printf("%d ", node);

        for (int i = 0; i < n; i++) {
            if (adj[node][i] == 1 && !visited[i]) {
                enqueue(i);
                visited[i] = 1;
            }
        }
    }
}

int main() {
    int n, m, u, v, s;

    scanf("%d", &n);   // number of nodes
    scanf("%d", &m);   // number of edges

    int adj[MAX][MAX] = {0};

    // input edges
    for (int i = 0; i < m; i++) {
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
        adj[v][u] = 1; // remove this line for directed graph
    }

    scanf("%d", &s); // source node

    BFS(n, adj, s);

    return 0;
}
